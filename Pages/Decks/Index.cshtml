@page
@model OceanCard.Pages.Decks.IndexModel
@{
    ViewData["Title"] = "我的牌組";
}

<a class="back-link" href="/Index">← 回首頁</a>
<h1>我的牌組</h1>

<form method="post" asp-page-handler="Create" class="deck-create">
    <input type="text" name="NewDeckName" placeholder="新牌組名稱…" />
    <button type="submit" class="filter-btn">建立牌組</button>
</form>

<form method="post" asp-page-handler="Random" style="margin-bottom:16px;">
    <button type="submit" class="filter-btn"
            style="background:transparent; border:1px solid var(--glow-teal); color:var(--glow-teal);">
        🎲 隨機生成 15 張牌組
    </button>
</form>

@if (Model.Decks.Count == 0)
{
    <div class="empty-state">還沒有牌組。在上面取個名字,建一套吧。</div>
}
else
{
    <div class="deck-list">
        @foreach (var deck in Model.Decks)
        {
            <div class="deck-row">
                <div>
                    <div class="deck-name">@deck.Name</div>
                    <div class="deck-count">@deck.Cards.Count 張卡</div>
                </div>
                <div class="deck-row-actions">
                    <a href="/Decks/Edit/@deck.Id">編輯</a>
                    <form method="post" asp-page-handler="Delete"
                          onsubmit="return confirm('確定刪除牌組「@deck.Name」?');"
                          style="display:inline;">
                        <input type="hidden" name="id" value="@deck.Id" />
                        <button type="submit" class="link-danger">刪除</button>
                    </form>
                </div>
            </div>
        }
    </div>
}